@using EventEase.Services
@inject SessionStateService SessionState
@inject NavigationManager Navigation
@implements IDisposable

<div class="user-session-container">
    @if (SessionState.CurrentUser != null)
    {
        <div class="user-info">
            <span class="welcome-text">
                <i class="bi bi-person-circle"></i>
                Welcome, @SessionState.CurrentUser.FullName
            </span>
            <button class="btn btn-outline-secondary btn-sm" @onclick="Logout">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>
        </div>
        
        @if (GetRemainingMinutes() < 5) @* 只有在剩余时间少于5分钟时才显示计时器 *@
        {
            <div class="session-timer" title="Session timeout in @GetRemainingMinutes() minutes">
                <i class="bi bi-clock"></i>
                <small>@GetRemainingMinutes():@GetRemainingSeconds().ToString("00")</small>
            </div>
        }
    }
    else
    {
        <div class="login-prompt">
            <a href="/login" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-box-arrow-in-right"></i> Login
            </a>
        </div>
    }
</div>

@code {
    private System.Timers.Timer? _timer;
    private int _remainingSeconds;
    
    protected override void OnInitialized()
    {
        // 订阅会话状态变化事件
        SessionState.UserSessionChanged += OnUserSessionChanged;
        
        // 立即检查当前状态
        CheckSessionAndStartTimer();
    }
    
    private void OnUserSessionChanged(object? sender, UserSessionChangedEventArgs e)
    {
        // 强制组件重新渲染
        InvokeAsync(() =>
        {
            StateHasChanged();
            CheckSessionAndStartTimer();
        });
    }
    
    private void CheckSessionAndStartTimer()
    {
        if (SessionState.CurrentUser != null)
        {
            StartTimer();
        }
        else
        {
            StopTimer();
        }
    }
    
    private void StartTimer()
    {
        StopTimer(); // 先停止现有计时器
        
        _timer = new System.Timers.Timer(1000);
        _timer.Elapsed += async (s, e) => await UpdateRemainingTime();
        _timer.Start();
    }
    
    private void StopTimer()
    {
        if (_timer != null)
        {
            _timer.Stop();
            _timer.Dispose();
            _timer = null;
        }
    }
    
    private async Task UpdateRemainingTime()
    {
        if (SessionState.CurrentUser != null)
        {
            var elapsed = DateTime.Now - SessionState.LastActivityTime;
            var remaining = TimeSpan.FromMinutes(30) - elapsed;
            _remainingSeconds = (int)remaining.TotalSeconds;
            
            if (_remainingSeconds <= 0)
            {
                StopTimer();
                await InvokeAsync(() => Navigation.NavigateTo("/login?timeout=true", true));
            }
            else
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        else
        {
            StopTimer();
        }
    }
    
    private int GetRemainingMinutes()
    {
        return Math.Max(0, _remainingSeconds / 60);
    }
    
    private int GetRemainingSeconds()
    {
        return Math.Max(0, _remainingSeconds % 60);
    }
    
    private async Task Logout()
    {
        await SessionState.LogoutAsync();
        Navigation.NavigateTo("/", true);
    }
    
    public void Dispose()
    {
        StopTimer();
        SessionState.UserSessionChanged -= OnUserSessionChanged;
    }
}

<style>
    .user-session-container {
        display: flex;
        align-items: center;
        gap: 15px;
    }
    
    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    
    .welcome-text {
        display: flex;
        align-items: center;
        gap: 5px;
        color: #333;
    }
    
    .session-timer {
        color: #dc3545;
        font-size: 0.9rem;
        font-weight: bold;
    }
    
    .session-timer i {
        margin-right: 3px;
        color: #dc3545;
    }
    
    .login-prompt {
        display: flex;
        align-items: center;
    }
</style>